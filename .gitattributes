# Auto-detect text files and normalise line endings
* text=auto

# Rust
*.rs text diff=rust
Cargo.toml text
Cargo.lock text -diff linguist-generated

# Web
*.ts text diff=typescript
*.tsx text diff=typescript
*.js text
*.css text
*.html text
*.json text

# Config
*.toml text
*.yaml text
*.yml text
*.md text

# Images
*.png binary
*.jpg binary
*.ico binary

# SQLite
*.db binary

# Force LF for shell scripts
*.sh text eol=lf

# Linguist overrides — keep language stats accurate
web/dist/** linguist-generated
Cargo.lock linguist-generated
